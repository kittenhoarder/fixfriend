# ── Portal passwords ──────────────────────────────────────────────────────────
# Copy this file to .env (or .env.local) and fill in your values.
# Restart the dev server after changes: npm run dev
#
# VITE_GATE_PASSWORD          — gates the main Raidical portal
# VITE_GATE_PASSWORD_ACQUIRER — gates the Acquirer portal
#
# Gate behaviour:
#   Neither set → both portals open, free switcher button
#   Only one set → gate on that portal + bypass button to the ungated one
#   Both set     → gate screen with toggle between the two password forms
#
# VITE_GATE_PASSWORD=
# VITE_GATE_PASSWORD_ACQUIRER=
