# Optional: when set, the app shows a password screen before allowing access.
# When unset or empty, the app loads without a gate.
#
# Vite does NOT load this file. Copy to .env (or .env.local) and set your value:
#   VITE_GATE_PASSWORD=your_password_here
# Then restart the dev server (npm run dev).
# VITE_GATE_PASSWORD=
